<table>
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">USERNAME</th>
        <th scope="col">AGE</th>
        <th scope="col">PLACE OF BIRTH</th>
        <th scope="col">CREATED AT</th>
        
    </tr>
    </thead>
    <tbody>
    {{#each sloniki}}
        <tr>
            <th scope="row">{{this.id}}</th>
            <td>{{this.username}}</td>
            <td>{{this.age}}</td>
            <td>{{this.place_of_birth}}</td>
            <td>{{this.created_at}}</td>
        </tr>
    {{/each}}
    </tbody>
</table>